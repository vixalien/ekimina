{
  "name": "@ekimina/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "forge test",
    "compile": "forge build && pnpm extract-abis",
    "extract-abis": "tsx scripts/extract-abis.ts",
    "deploy": "forge script script/DeployCelo.s.sol --broadcast --rpc-url celoSepolia",
    "deploy:sepolia": "forge script script/DeployCelo.s.sol --broadcast --rpc-url sepolia",
    "read-state": "tsx scripts/read-state.ts",
    "check-wallet": "tsx scripts/check-wallet.ts",
    "dev:deploy": "tsx scripts/deploy-local.ts",
    "dev:node": "anvil --state .anvil-state --port 8545 --disable-code-size-limit",
    "predev": "pnpm compile",
    "dev": "concurrently \"pnpm dev:node\" \"wait-on tcp:8545 && pnpm dev:deploy\""
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "typescript": "~6.0.3",
    "viem": "^2.52.0"
  },
  "devDependencies": {
    "@ekimina/types": "workspace:*",
    "@types/node": "^22.19.19",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "wait-on": "^9.0.10"
  }
}
